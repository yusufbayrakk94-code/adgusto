rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection - each user can only read/write their own data
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // User subcollections - each user can only access their own data
      match /{subCollection}/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // User subscriptions - each user can only access their own subscription data
    match /subscriptions/{userId} {
      allow read, write: if isOwner(userId);
    }

    // User campaigns - each user can only access their own campaigns
    match /campaigns/{campaignId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // User analyses - each user can only access their own analyses
    match /analyses/{analysisId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // User generated images - each user can only access their own images
    match /generatedImages/{imageId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Meta Ads connections - each user can only access their own connection
    match /meta_ads_connections/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Meta Ads campaigns - each user can only access their own campaigns
    match /meta_ad_campaigns/{campaignId} {
      allow read, write, delete: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // Block all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
